# ============================================================
# RECYCLOPS - Environment Variables Example
# Copy this file to .env and fill in the actual values
# ============================================================

# AWS Configuration
AWS_REGION=us-east-1

# ============================================================
# ACCESSIBILITY ANALYZER SERVICE
# ============================================================

# GitHub Integration
GITHUB_TOKEN=ghp_your_github_token_here

# SQS Configuration
SQS_URL=https://sqs.us-east-1.amazonaws.com/656661782834/recyclops-accessibility.fifo
DLQ_URL=https://sqs.us-east-1.amazonaws.com/656661782834/recyclops-analyzer-dlq.fifo

# DynamoDB Tables
DYNAMODB_REPORTS=recyclops-reports
DYNAMODB_BYPASS=recyclops-bypass-rules

# Service URLs
CERS_IA_URL=http://localhost:8000
BYPASS_API_URL=http://localhost:8001

# Analysis Configuration
SCORE_THRESHOLD=50

# ============================================================
# RECYCLOPS SERVICE (LLM)
# ============================================================

# OpenAI Configuration
OPENAI_API_KEY=sk_your_openai_api_key_here

# ============================================================
# WEBHOOK LAMBDA
# ============================================================

# SSM Parameter name for webhook secret
WEBHOOK_SECRET_PARAM=/recyclops/GITHUB_WEBHOOK_SECRET

# ============================================================
# LOCAL DEVELOPMENT (optional)
# ============================================================

# Docker & Development
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# FastAPI
ENVIRONMENT=development
DEBUG=true

# Logging
LOG_LEVEL=DEBUG
